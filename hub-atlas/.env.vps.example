# Copie para .env NO VPS (não versione o .env real):  cp .env.vps.example .env
# Depois preencha os valores. Nada aqui aponta pro Neon — o Postgres é local.

# --- Domínio (Caddy usa pra emitir o certificado HTTPS) ---
# Aponte um A record desse domínio pro IP do VPS antes de subir.
DOMAIN=hub.seudominio.com.br

# --- Postgres local ---
# Troque por uma senha forte. Só é usada dentro da rede do compose.
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# --- Banco (app + migrations apontam pro Postgres local) ---
# Local, sem pooler: DATABASE_URL e DIRECT_URL são iguais.
DATABASE_URL=postgresql://atlas:troque-por-uma-senha-forte@db:5432/atlas?schema=public
DIRECT_URL=postgresql://atlas:troque-por-uma-senha-forte@db:5432/atlas?schema=public

# --- Clerk ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# --- Google Calendar (OAuth por usuário) ---
# Credenciais do console.cloud.google.com > Credenciais > ID do cliente OAuth (Web).
# O redirect autorizado precisa ser exatamente: $APP_URL/api/google/callback
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# Base pública da aplicação (usada pra montar o redirect_uri do OAuth).
APP_URL=https://hub.seudominio.com.br

# URLs do Clerk (têm defaults sensatos; descomente só se quiser mudar)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/portal
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/portal
