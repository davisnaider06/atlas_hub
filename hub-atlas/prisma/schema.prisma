// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  /// Sócio: acesso total, incluindo gerenciar a equipe.
  OWNER
  /// Administrador: opera o CRM e o catálogo, mas não mexe na equipe.
  ADMIN
  /// Colaborador: trabalha leads e agendamentos, sem acesso a serviços/equipe.
  MEMBER
  /// Cliente: só o portal.
  CLIENT
}

// Sincronizado com o Clerk via webhook (clerkId = user id do Clerk).
//
// `clerkId` é opcional pra permitir PRÉ-CADASTRO: o sócio cadastra a pessoa na
// tela de Equipe com email e papel antes dela existir; no primeiro login o
// registro é casado por email e o clerkId preenchido.
model User {
  id        String   @id @default(cuid())
  clerkId   String?  @unique
  email     String   @unique
  name      String?
  role      Role     @default(CLIENT)
  /// Quem convidou; nulo para quem entrou sozinho pelo cadastro público.
  invitedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact   Contact?      @relation(fields: [contactId], references: [id])
  contactId String?       @unique
  documents Document[]

  // agendamentos em que este usuário é o atendente
  appointments Appointment[]

  googleAccount GoogleAccount?
  tasks         Task[]
  expenses      Expense[]
}

// Conexão OAuth de um membro do time com o Google Calendar.
//
// É por usuário (e não uma service account) porque a Atlas usa contas Gmail
// comuns, sem Google Workspace — então não há domain-wide delegation possível.
// Cada atendente conecta a própria agenda.
model GoogleAccount {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // email da conta Google conectada (pode diferir do email do Clerk)
  googleEmail String

  // Agenda dedicada "Atlas Agendamentos". O Hub só lê e escreve nela — nunca
  // na agenda pessoal, senão compromisso particular viraria lead no CRM.
  // Fica nulo até a agenda ser criada/localizada no primeiro uso.
  calendarId String?

  // Token de sincronização incremental do Google: na próxima leitura ele
  // devolve só o que mudou desde a última vez, em vez da agenda inteira.
  syncToken String?

  accessToken  String
  refreshToken String
  // quando o accessToken expira; usamos o refreshToken pra renovar
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Coluna do kanban do pipeline de CRM.
model PipelineStage {
  id       String    @id @default(cuid())
  name     String
  order    Int       @unique
  contacts Contact[]
}

enum ContactType {
  LEAD
  CLIENT
}

// Serviço oferecido pela Atlas (site, software, automação com IA...).
// Preços em CENTAVOS: dinheiro em float acumula erro de arredondamento, e
// inteiro serializa limpo do servidor pro cliente.
model Service {
  id            String  @id @default(cuid())
  name          String
  description   String?
  // faixa de negociação: piso e teto
  priceMinCents Int?
  priceMaxCents Int?
  // desativado some dos seletores mas continua nos clientes que já contrataram
  active        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts  Contact[]
  contracts Contract[]
}

// Lead ou cliente. Vira CLIENT automaticamente ao entrar no estágio de
// "Fechado - Ganho"; aí passa a fazer sentido registrar o serviço contratado.
model Contact {
  id        String      @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?
  type      ContactType @default(LEAD)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // serviço contratado e valor fechado (só fazem sentido quando type=CLIENT)
  serviceId          String?
  service            Service? @relation(fields: [serviceId], references: [id])
  contractValueCents Int?

  stageId String
  stage   PipelineStage @relation(fields: [stageId], references: [id])

  user         User?
  appointments Appointment[]
  tasks        Task[]
  documents    Document[]
  contracts    Contract[]

  @@index([stageId])
  @@index([email])
}

enum ContractType {
  /// Projeto pontual: valor fechado, geralmente parcelado.
  ONE_OFF
  /// Recorrente: mensalidade (manutenção, hospedagem, automação de IA).
  RECURRING
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

/// Contrato de um cliente. Um cliente pode ter vários (ex: um projeto + uma
/// manutenção recorrente), por isso não fica direto no Contact.
model Contract {
  id     String         @id @default(cuid())
  title  String?
  type   ContractType
  status ContractStatus @default(ACTIVE)

  /// ONE_OFF usa totalCents; RECURRING usa monthlyCents. Centavos (Int) porque
  /// dinheiro em float acumula erro de arredondamento.
  totalCents   Int?
  monthlyCents Int?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  installments Installment[]

  @@index([contactId])
  @@index([status])
}

enum InstallmentStatus {
  PENDING
  PAID
}

/// Parcela de um contrato. O status "atrasado" NÃO é guardado: é derivado no
/// código (vencimento passou + ainda PENDING), pra não precisar de um cron
/// virando status todo dia.
model Installment {
  id     String            @id @default(cuid())
  number Int
  amountCents Int
  dueDate     DateTime
  status      InstallmentStatus @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime          @default(now())

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([status, dueDate])
}

enum ExpenseCategory {
  PAYROLL
  TOOLS
  MARKETING
  INFRA
  TAXES
  OTHER
}

/// Despesa da Atlas. Visível SÓ pra sócios (capacidade finance.expenses).
model Expense {
  id          String          @id @default(cuid())
  description String
  amountCents Int
  category    ExpenseCategory @default(OTHER)
  spentAt     DateTime
  /// custo fixo que se repete todo mês (aluguel, salário, ferramenta)
  recurring   Boolean         @default(false)
  notes       String?
  createdAt   DateTime        @default(now())

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@index([spentAt])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

model Appointment {
  id        String            @id @default(cuid())
  title     String
  startsAt  DateTime
  endsAt    DateTime
  status    AppointmentStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Cliente atendido. Opcional porque um evento criado direto no Google pode
  // não ter convidado que case com um Contact — ainda assim queremos importá-lo.
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  // atendente: é na agenda do Google DELE que o evento é criado
  assignedToId String
  assignedTo   User   @relation(fields: [assignedToId], references: [id])

  // preenchidos quando o evento é espelhado no Google Calendar (Fase C).
  // Nulos = agendamento existe só no Hub.
  googleEventId    String?
  googleCalendarId String?

  @@index([contactId])
  @@index([startsAt])
  @@index([assignedToId])
}

enum TaskStatus {
  PENDING
  DONE
}

enum TaskKind {
  /// Retomar contato com um lead parado
  FOLLOW_UP
  /// Ligar / mandar mensagem
  CALL
  /// Enviar proposta
  PROPOSAL
  /// Tarefa livre
  OTHER
}

/// Tarefa da rotina diária de um membro do time.
model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  kind        TaskKind   @default(OTHER)
  status      TaskStatus @default(PENDING)
  /// Data em que a tarefa deve ser feita (usada pra montar a rotina do dia).
  dueAt       DateTime
  doneAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Responsável pela tarefa.
  assignedToId String
  assignedTo   User   @relation(fields: [assignedToId], references: [id], onDelete: Cascade)

  /// Lead/cliente relacionado, quando houver.
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([assignedToId, status, dueAt])
  @@index([contactId])
}

enum DocumentScope {
  /// Material de um lead/cliente específico (proposta, contrato...).
  CONTACT
  /// Documento interno da Atlas, sem dono: script, planejamento, escopo.
  INTERNAL
}

enum DocumentCategory {
  SCRIPT
  PLANNING
  SCOPE
  CONTRACT
  PROPOSAL
  OTHER
}

model Document {
  id          String  @id @default(cuid())
  /// Nome original do arquivo enviado.
  fileName    String
  /// Nome amigável exibido nas listas; cai pro fileName quando vazio.
  title       String?
  description String?

  /// Caminho relativo dentro do diretório de uploads.
  /// (Antes era gcsObjectKey, de quando o plano era Google Cloud Storage.)
  storageKey String
  mimeType   String
  sizeBytes  Int

  scope    DocumentScope
  category DocumentCategory @default(OTHER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Preenchido só quando scope = CONTACT.
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  @@index([contactId])
  @@index([scope, category])
}
