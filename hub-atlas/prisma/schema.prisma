// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  /// Sócio: acesso total, incluindo gerenciar a equipe.
  OWNER
  /// Administrador: opera o CRM e o catálogo, mas não mexe na equipe.
  ADMIN
  /// Colaborador: trabalha leads e agendamentos, sem acesso a serviços/equipe.
  MEMBER
  /// Cliente: só o portal.
  CLIENT
}

// Sincronizado com o Clerk via webhook (clerkId = user id do Clerk).
//
// `clerkId` é opcional pra permitir PRÉ-CADASTRO: o sócio cadastra a pessoa na
// tela de Equipe com email e papel antes dela existir; no primeiro login o
// registro é casado por email e o clerkId preenchido.
model User {
  id        String   @id @default(cuid())
  clerkId   String?  @unique
  email     String   @unique
  name      String?
  role      Role     @default(CLIENT)
  /// Quem convidou; nulo para quem entrou sozinho pelo cadastro público.
  invitedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact   Contact?      @relation(fields: [contactId], references: [id])
  contactId String?       @unique
  documents Document[]

  // agendamentos em que este usuário é o atendente
  appointments Appointment[]

  googleAccount GoogleAccount?
  tasks         Task[]
}

// Conexão OAuth de um membro do time com o Google Calendar.
//
// É por usuário (e não uma service account) porque a Atlas usa contas Gmail
// comuns, sem Google Workspace — então não há domain-wide delegation possível.
// Cada atendente conecta a própria agenda.
model GoogleAccount {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // email da conta Google conectada (pode diferir do email do Clerk)
  googleEmail String

  // Agenda dedicada "Atlas Agendamentos". O Hub só lê e escreve nela — nunca
  // na agenda pessoal, senão compromisso particular viraria lead no CRM.
  // Fica nulo até a agenda ser criada/localizada no primeiro uso.
  calendarId String?

  // Token de sincronização incremental do Google: na próxima leitura ele
  // devolve só o que mudou desde a última vez, em vez da agenda inteira.
  syncToken String?

  accessToken  String
  refreshToken String
  // quando o accessToken expira; usamos o refreshToken pra renovar
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Coluna do kanban do pipeline de CRM.
model PipelineStage {
  id       String    @id @default(cuid())
  name     String
  order    Int       @unique
  contacts Contact[]
}

enum ContactType {
  LEAD
  CLIENT
}

// Serviço oferecido pela Atlas (site, software, automação com IA...).
// Preços em CENTAVOS: dinheiro em float acumula erro de arredondamento, e
// inteiro serializa limpo do servidor pro cliente.
model Service {
  id            String  @id @default(cuid())
  name          String
  description   String?
  // faixa de negociação: piso e teto
  priceMinCents Int?
  priceMaxCents Int?
  // desativado some dos seletores mas continua nos clientes que já contrataram
  active        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]
}

// Lead ou cliente. Vira CLIENT automaticamente ao entrar no estágio de
// "Fechado - Ganho"; aí passa a fazer sentido registrar o serviço contratado.
model Contact {
  id        String      @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?
  type      ContactType @default(LEAD)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // serviço contratado e valor fechado (só fazem sentido quando type=CLIENT)
  serviceId          String?
  service            Service? @relation(fields: [serviceId], references: [id])
  contractValueCents Int?

  stageId String
  stage   PipelineStage @relation(fields: [stageId], references: [id])

  user         User?
  appointments Appointment[]
  tasks        Task[]
  documents    Document[]

  @@index([stageId])
  @@index([email])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

model Appointment {
  id        String            @id @default(cuid())
  title     String
  startsAt  DateTime
  endsAt    DateTime
  status    AppointmentStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Cliente atendido. Opcional porque um evento criado direto no Google pode
  // não ter convidado que case com um Contact — ainda assim queremos importá-lo.
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  // atendente: é na agenda do Google DELE que o evento é criado
  assignedToId String
  assignedTo   User   @relation(fields: [assignedToId], references: [id])

  // preenchidos quando o evento é espelhado no Google Calendar (Fase C).
  // Nulos = agendamento existe só no Hub.
  googleEventId    String?
  googleCalendarId String?

  @@index([contactId])
  @@index([startsAt])
  @@index([assignedToId])
}

enum TaskStatus {
  PENDING
  DONE
}

enum TaskKind {
  /// Retomar contato com um lead parado
  FOLLOW_UP
  /// Ligar / mandar mensagem
  CALL
  /// Enviar proposta
  PROPOSAL
  /// Tarefa livre
  OTHER
}

/// Tarefa da rotina diária de um membro do time.
model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  kind        TaskKind   @default(OTHER)
  status      TaskStatus @default(PENDING)
  /// Data em que a tarefa deve ser feita (usada pra montar a rotina do dia).
  dueAt       DateTime
  doneAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Responsável pela tarefa.
  assignedToId String
  assignedTo   User   @relation(fields: [assignedToId], references: [id], onDelete: Cascade)

  /// Lead/cliente relacionado, quando houver.
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([assignedToId, status, dueAt])
  @@index([contactId])
}

model Document {
  id           String   @id @default(cuid())
  fileName     String
  gcsObjectKey String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  @@index([contactId])
}
